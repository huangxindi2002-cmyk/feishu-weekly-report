# ===== 飞书应用（自建应用，用于读知识库电子表格）=====
# 开发者后台 https://open.feishu.cn → 创建企业自建应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 知识库链接 或 直接给 wiki node token（二选一，URL 优先）
# 链接形如 https://my.feishu.cn/wiki/PGXhwwca8i7j5TkSBm1c1VlBnAf
FEISHU_WIKI_URL=https://my.feishu.cn/wiki/PGXhwwca8i7j5TkSBm1c1VlBnAf
# FEISHU_WIKI_TOKEN=PGXhwwca8i7j5TkSBm1c1VlBnAf

# 飞书 API 域名：中国版 open.feishu.cn / 国际版 open.larksuite.com
FEISHU_BASE_URL=https://open.feishu.cn

# ===== Claude API =====
ANTHROPIC_API_KEY=

# ===== 飞书群机器人 Webhook（自定义机器人）=====
FEISHU_WEBHOOK_URL=
# 若机器人开启了「签名校验」，填这里；没开就留空
FEISHU_WEBHOOK_SECRET=

# ===== GitHub Pages 部署 =====
# 仓库，格式 username/repo-name；用于拼出 Pages 链接
GITHUB_REPO=
# 触发 Pages 部署的 token（本地 push 用，Actions 内用内置 GITHUB_TOKEN 即可）
GITHUB_TOKEN=
